            // vòng lặp MAP như for nhưng cách dùng khác nhau:

            // vong lặp này có 1 điểm là k cần đếm i=0 va length gi hết,

            // có bnhieu value va key thi nó tự lấy ra hết

            // value va key bên trong này cũng chinh la value va key của mang1

             
            // xx = []
            mang1.map(function(value, key ){
                // // // lay value ra
                // console.log(value)
               
                // lấy key ra
                // console.log(key)

                // tuong tự for, muốn lay 1 cái ra thôi, vdu
